# Google AI Studio / Generative Language API (one of these is enough)
GEMINI_API_KEY=
# GOOGLE_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# Optional: model id supported by your API key (default: gemini-2.0-flash)
GEMINI_MODEL=gemini-2.0-flash
# Set to "true" to enable Google Search grounding when supported for your model/account
GEMINI_USE_GOOGLE_SEARCH=false
